#!/bin/sh
# configure — detect build-time options and generate config.mk

AUDIO=auto
UDEV=auto
LAME=auto
PIPEWIRE=auto

for arg in "$@"; do
    case "$arg" in
        --disable-audio)    AUDIO=no ;;
        --enable-audio)     AUDIO=yes ;;
        --disable-udev)     UDEV=no ;;
        --disable-lame)     LAME=no ;;
        --disable-pipewire) PIPEWIRE=no ;;
        --help|-h)
            cat <<EOF
Usage: ./configure [OPTION]...

Options:
  --disable-audio     Build without audio support
  --enable-audio      Require audio support (fail if no backend found)
  --disable-udev      Disable libudev; use sysfs-only device autodetection
  --disable-lame      Build without MP3 recording support
  --disable-pipewire  Use ALSA directly even if PipeWire is available

Without options, PipeWire is used when available; otherwise falls back to ALSA.
When audio is enabled, libudev is used for device autodetection if available.
With PipeWire, both capture and playback go through PipeWire (no libasound).
With ALSA, both capture and playback use libasound.
EOF
            exit 0
            ;;
        *)
            echo "configure: unknown option: $arg" >&2
            echo "Try './configure --help' for more information." >&2
            exit 1
            ;;
    esac
done

have_audio=no
have_alsa=no
have_pipewire=no
have_udev=no
have_lame=no

# ── PipeWire (preferred backend) ─────────────────────────────────────────
if [ "$AUDIO" != "no" ] && [ "$PIPEWIRE" != "no" ]; then
    printf "checking for libpipewire-0.3... "
    if pkg-config --exists libpipewire-0.3 2>/dev/null; then
        have_pipewire=yes
        have_audio=yes
        echo "yes ($(pkg-config --modversion libpipewire-0.3))"
    else
        echo "no"
    fi
fi

# ── ALSA (fallback when PipeWire not available or --disable-pipewire) ────
if [ "$AUDIO" != "no" ] && [ "$have_pipewire" = "no" ]; then
    printf "checking for libasound... "

    if pkg-config --exists alsa 2>/dev/null; then
        have_alsa=yes
        have_audio=yes
        echo "yes (pkg-config)"
    else
        _tmpdir=$(mktemp -d)
        cat > "$_tmpdir/check.c" <<'EOF'
#include <alsa/asoundlib.h>
int main(void) { return 0; }
EOF
        if ${CC:-gcc} "$_tmpdir/check.c" -lasound -o "$_tmpdir/check" 2>/dev/null; then
            have_alsa=yes
            have_audio=yes
            echo "yes"
        else
            echo "no"
            if [ "$AUDIO" = "yes" ]; then
                echo "configure: error: no audio backend found (tried libpipewire-0.3, libasound)" >&2
                rm -rf "$_tmpdir"
                exit 1
            fi
        fi
        rm -rf "$_tmpdir"
    fi
fi

if [ "$AUDIO" = "yes" ] && [ "$have_audio" = "no" ]; then
    echo "configure: error: --enable-audio requires libpipewire-0.3 or libasound" >&2
    exit 1
fi

# ── libudev (autodetection helper, useful for both backends) ─────────────
if [ "$have_audio" = "yes" ] && [ "$UDEV" != "no" ]; then
    printf "checking for libudev... "

    if pkg-config --exists libudev 2>/dev/null; then
        have_udev=yes
        echo "yes (pkg-config)"
    else
        _tmpdir=$(mktemp -d)
        cat > "$_tmpdir/check.c" <<'EOF'
#include <libudev.h>
int main(void) { struct udev *u = udev_new(); udev_unref(u); return 0; }
EOF
        if ${CC:-gcc} "$_tmpdir/check.c" -ludev -o "$_tmpdir/check" 2>/dev/null; then
            have_udev=yes
            echo "yes"
        else
            echo "no (will use sysfs-based autodetection)"
        fi
        rm -rf "$_tmpdir"
    fi
fi

# ── libmp3lame (recording, works with either backend) ────────────────────
if [ "$have_audio" = "yes" ] && [ "$LAME" != "no" ]; then
    printf "checking for libmp3lame... "
    _tmpdir=$(mktemp -d)
    cat > "$_tmpdir/check.c" <<'EOF'
#include <lame/lame.h>
int main(void) { lame_global_flags *l = lame_init(); lame_close(l); return 0; }
EOF
    if ${CC:-gcc} "$_tmpdir/check.c" -lmp3lame -o "$_tmpdir/check" 2>/dev/null; then
        have_lame=yes
        echo "yes"
    else
        echo "no"
    fi
    rm -rf "$_tmpdir"
fi

# ── Build flag strings ────────────────────────────────────────────────────
if [ "$have_audio" = "yes" ]; then
    audio_srcs="audio.c"
    record_srcs=$([ "$have_lame" = "yes" ] && echo "record.c")

    # Common udev fragment (shared by both backends)
    udev_cflags=""
    udev_libs=""
    if [ "$have_udev" = "yes" ]; then
        udev_cflags="-DHAVE_UDEV"
        udev_libs="-ludev"
        _udev_ver=$(pkg-config --modversion libudev 2>/dev/null)
        if [ -n "$_udev_ver" ]; then
            udev_cflags="$udev_cflags -DLIBUDEV_VERSION=\\\"$_udev_ver\\\""
        fi
    fi
    lame_cflags=$([ "$have_lame" = "yes" ] && echo "-DHAVE_LAME")
    lame_libs=$([ "$have_lame" = "yes" ] && echo "-lmp3lame")

    if [ "$have_pipewire" = "yes" ]; then
        audio_cflags="-DHAVE_AUDIO -DHAVE_PIPEWIRE $(pkg-config --cflags libpipewire-0.3) $udev_cflags $lame_cflags"
        audio_libs="$(pkg-config --libs libpipewire-0.3) $udev_libs $lame_libs"
    else
        audio_cflags="-DHAVE_AUDIO $udev_cflags $lame_cflags"
        audio_libs="-lasound $udev_libs $lame_libs"
    fi
else
    audio_cflags=""
    audio_libs=""
    audio_srcs=""
    record_srcs=""
fi

cat > config.mk <<EOF
# Generated by ./configure — do not edit
HAVE_AUDIO   = $([ "$have_audio" = "yes" ] && echo 1 || echo 0)
AUDIO_CFLAGS = $audio_cflags
AUDIO_SRCS   = $audio_srcs
AUDIO_LIBS   = $audio_libs
RECORD_SRCS  = $record_srcs
EOF

echo ""
echo "Build configuration:"
if [ "$have_pipewire" = "yes" ]; then
    printf "  Audio backend:         PipeWire\n"
elif [ "$have_alsa" = "yes" ]; then
    printf "  Audio backend:         ALSA\n"
else
    printf "  Audio backend:         disabled\n"
fi
if [ "$have_audio" = "yes" ]; then
    printf "  Device autodetect:     "
    [ "$have_udev" = "yes" ] && echo "udev + sysfs fallback" || echo "sysfs"
    printf "  MP3 recording:         "
    [ "$have_lame" = "yes" ] && echo "enabled" || echo "disabled (libmp3lame not found)"
fi
echo ""
echo "Run 'make' to build."
