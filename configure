#!/bin/sh
# configure — detect build-time options and generate config.mk

AUDIO=auto

for arg in "$@"; do
    case "$arg" in
        --disable-audio) AUDIO=no ;;
        --enable-audio)  AUDIO=yes ;;
        --help|-h)
            cat <<EOF
Usage: ./configure [OPTION]...

Options:
  --disable-audio   Build without ALSA audio support
  --enable-audio    Require ALSA audio support (fail if not found)
  --help            Show this help

Without options, audio support is enabled automatically if libasound is found.
When audio is enabled, libudev is used for ALSA autodetection if available;
otherwise the build falls back to sysfs-based detection.
EOF
            exit 0
            ;;
        *)
            echo "configure: unknown option: $arg" >&2
            echo "Try './configure --help' for more information." >&2
            exit 1
            ;;
    esac
done

have_audio=no

if [ "$AUDIO" != "no" ]; then
    printf "checking for libasound... "

    if pkg-config --exists alsa 2>/dev/null; then
        have_audio=yes
        echo "yes (pkg-config)"
    else
        _tmpdir=$(mktemp -d)
        cat > "$_tmpdir/check.c" <<'EOF'
#include <alsa/asoundlib.h>
int main(void) { return 0; }
EOF
        if ${CC:-gcc} "$_tmpdir/check.c" -lasound -o "$_tmpdir/check" 2>/dev/null; then
            have_audio=yes
            echo "yes"
        else
            echo "no"
            if [ "$AUDIO" = "yes" ]; then
                echo "configure: error: libasound not found (required by --enable-audio)" >&2
                rm -rf "$_tmpdir"
                exit 1
            fi
        fi
        rm -rf "$_tmpdir"
    fi
fi

have_udev=no

if [ "$have_audio" = "yes" ]; then
    printf "checking for libudev... "

    if pkg-config --exists libudev 2>/dev/null; then
        have_udev=yes
        echo "yes (pkg-config)"
    else
        _tmpdir=$(mktemp -d)
        cat > "$_tmpdir/check.c" <<'EOF'
#include <libudev.h>
int main(void) { struct udev *u = udev_new(); udev_unref(u); return 0; }
EOF
        if ${CC:-gcc} "$_tmpdir/check.c" -ludev -o "$_tmpdir/check" 2>/dev/null; then
            have_udev=yes
            echo "yes"
        else
            echo "no (will use sysfs-based autodetection)"
        fi
        rm -rf "$_tmpdir"
    fi
fi

# Build flag strings
if [ "$have_audio" = "yes" ]; then
    audio_cflags="-DHAVE_AUDIO"
    audio_libs="-lasound"
    if [ "$have_udev" = "yes" ]; then
        audio_cflags="$audio_cflags -DHAVE_UDEV"
        audio_libs="$audio_libs -ludev"
    fi
    audio_srcs="audio.c"
else
    audio_cflags=""
    audio_libs=""
    audio_srcs=""
fi

cat > config.mk <<EOF
# Generated by ./configure — do not edit
HAVE_AUDIO   = $([ "$have_audio" = "yes" ] && echo 1 || echo 0)
AUDIO_CFLAGS = $audio_cflags
AUDIO_SRCS   = $audio_srcs
AUDIO_LIBS   = $audio_libs
EOF

echo ""
echo "Build configuration:"
printf "  Audio (ALSA): "
[ "$have_audio" = "yes" ] && echo "enabled" || echo "disabled"
if [ "$have_audio" = "yes" ]; then
    printf "  ALSA autodetect via: "
    [ "$have_udev" = "yes" ] && echo "udev + sysfs fallback" || echo "sysfs"
fi
echo ""
echo "Run 'make' to build."
